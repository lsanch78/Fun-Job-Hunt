# Supabase (server-side service role key — never expose to browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LinkedIn session cookies (exported from browser; treat as a password)
LINKEDIN_COOKIES_JSON=[]

# Handshake credentials
HANDSHAKE_EMAIL=you@example.com
HANDSHAKE_PASSWORD=changeme

# Telegram bot
TELEGRAM_BOT_TOKEN=<bot-token>
TELEGRAM_CHAT_ID=<your-chat-id>

# Worker behaviour
SCRAPE_INTERVAL_MS=900000
MATCH_SCORE_THRESHOLD=50
